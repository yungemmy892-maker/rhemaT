# Copy this file to .env and fill in real values for local development.

# Base URL of the Django backend's versioned API.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Google OAuth client ID (from Google Cloud Console > APIs & Services >
# Credentials). Must be the SAME client ID configured as GOOGLE_CLIENT_ID in
# the backend's .env — Google issues ID tokens for a specific client/audience
# and the backend verifies that the token's audience matches its own
# GOOGLE_CLIENT_ID.
#
# In Google Cloud Console, add these as "Authorized JavaScript origins" for
# this client ID:
#   http://localhost:3000
#   http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# VAPID public key for Web Push notifications.
# Generate with: python manage.py generate_vapid_keys (in the backend directory)
# Must match VAPID_PUBLIC_KEY in backend/.env exactly.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
