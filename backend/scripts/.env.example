# Copy this file to .env and fill in real values for local development.

# --- Django ---
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- MongoDB ---
# Local: mongodb://localhost:27017/verseid
# Atlas: mongodb+srv://<user>:<password>@<cluster-url>/verseid?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/verseid

# --- JWT ---
# If unset, falls back to DJANGO_SECRET_KEY. Use a separate, dedicated
# secret in production.
JWT_SECRET=change-this-to-a-different-long-random-string
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# --- Google OAuth ---
# From Google Cloud Console > APIs & Services > Credentials.
# Must match the client ID configured in the frontend's .env
# (VITE_GOOGLE_CLIENT_ID / equivalent) — Google ID tokens are issued for a
# specific client ID and this backend verifies that audience claim.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# --- Paystack (Nigerian payment processor for Pro subscriptions) ---
# From https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- CORS ---
# Comma-separated list of frontend origins allowed to call this API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
